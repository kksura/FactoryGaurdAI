# Copy to .env and fill in real values. `.env` is gitignored — never commit it.
# All values below are FAKE placeholders.

FG_ENVIRONMENT=local

# Dev-only JWT signing secret for the local auth provider (any random string).
# Generate one:  python -c "import secrets; print(secrets.token_urlsafe(48))"
FG_AUTH__LOCAL_JWT_SECRET=replace-with-random-string

# Local service credentials (docker compose reads these too).
FG_DATABASE__PASSWORD=replace-me-local-db-password
FG_STORAGE__ACCESS_KEY=replace-me-minio-access
FG_STORAGE__SECRET_KEY=replace-me-minio-secret

# Optional LLM summarizer (disabled when unset). Never required.
# ANTHROPIC_API_KEY=

# Optional TabPFN challenger weights license token (free account at
# https://ux.priorlabs.ai). Without it the challenger reports unavailable.
# TABPFN_TOKEN=
