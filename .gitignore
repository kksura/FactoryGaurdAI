# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.python-version

# Tooling caches
.mypy_cache/
.ruff_cache/
.pytest_cache/
.hypothesis/
.coverage
coverage.xml
htmlcov/

# Secrets and local env — never commit
.env
.env.*
!.env.example
*.pem
*.key
*.pfx
*.p12
/secrets/

# Data, models, experiment artifacts (generated, reproducible).
# NOTE: these are anchored to the repo root (leading slash). An earlier
# unanchored `data/` here silently matched src/factoryguard/data/,
# configs/data/, and pipelines/data/ too, excluding real source code from
# git for the whole of Phase 2-3 until caught before the Phase 3 commit.
/data/
!sample_data/
/mlruns/
/mlartifacts/
/artifacts/
/reports/
*.ckpt
*.onnx
*.safetensors
*.pt
*.pth

# Local services state
.minio/
.postgres/
*.db
*.sqlite

# IaC local state
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.example.tfvars

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp

# Reports that are regenerated
/sbom/*.json
